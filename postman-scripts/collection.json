    {
      "name": "create a duplicate repository for the authenticated user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// set the repo name as global variable. \r",
              "pm.globals.set(\"repoName\",\"PlaywrightAutomation\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// validate the status code of the duplicate repository creation\r",
              "pm.test(\"validate the status code of the duplicate repository\",function(){\r",
              "    pm.expect(pm.response.code).to.eql(422)\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"validate the error message for duplicate repository\",function(){\r",
              "    pm.expect(pm.response.json().message).to.eql(\"Repository creation failed.\")\r",
              "    });\r",
              "\r",
              "    pm.test\r",
              "    (\"validate the error code for duplicate repository\",function(){\r",
              "        pm.expect(pm.response.json().errors[0].code).to.eql(\"custom\")\r",
              "        });\r",
              "\r",
              "        pm.test(\"validate the status message\",function(){\r",
              "            pm.expect(pm.response.status).to.include(\"Unprocessable Entity\")\r",
              "\r",
              "        });\r",
              "\r",
              "        pm.test(\"validate the response time\",function(){\r",
              "          pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "        });\r",
              "        \r",
              "        pm.test(\"vaidate the schema of duplicate repository\", function(){\r",
              "          pm.expect(typeof (pm.response.json().message)).to.eql(\"string\")\r",
              "\r",
              "        });\r",
              "        setTimeout(()=>{\r",
              "          console.log(\"waiting for 2 seconds\");\r",
              "             },2000); "
            ],
