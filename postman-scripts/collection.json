  "item": [
    {
      "name": "create a valid repository for the authenticated user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// set the repo name as global variable\r",
              "pm.globals.set(\"repoName\", \"AutomationTesting\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// validate the status code of the valid repository creation\r",
              "pm.test(\"validate the status code of the valid repository\",function(){\r",
              "    pm.expect(pm.response.code).to.eql(201)\r",
              "\r",
              "});\r",
              " pm.test(\"validate the status message\",function(){\r",
              "    pm.expect(pm.response.status).to.include(\"Created\")\r",
              "\r",
              "     });\r",
              "\r",
              "  pm.test(\"validate the response body of the valid repository\",function(){\r",
              "    pm.expect(pm.response.json().name).to.eql(pm.globals.get(\"repoName\"));\r",
              "    pm.expect(pm.response.json().private).to.eql(true);\r",
              "\r",
              "  });  \r",
              "\r",
              " pm.test(\"validate the response time\",function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000)\r",
              "        });\r",
              "        \r",
              " pm.test(\"validate the schema of valid repository\", function(){\r",
              "    pm.expect(typeof(pm.response.json().name)).to.eql(\"string\")\r",
              "\r",
              "        });\r",
              "\r",
              "  setTimeout(()=>{\r",
              "     console.log(\"waiting for 2 seconds\");\r",
              "  },2000);      "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{bearer_token}}"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"{{repoName}}\",\r\n    \"private\":true,\r\n    \"description\":\"create a valid  repo\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/user/repos",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
    },
